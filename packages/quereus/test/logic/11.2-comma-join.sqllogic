-- adapted from SQLite test/join3.test, join.test
-- Comma syntax in FROM (implicit cross join): 2 tables, 3 tables, with WHERE.

create table cj_a (id integer primary key, va text);
create table cj_b (id integer primary key, vb text);

insert into cj_a values (1, 'a1'), (2, 'a2');
insert into cj_b values (10, 'b1'), (20, 'b2'), (30, 'b3');

-- Two-table comma list with no WHERE: full cartesian product
select count(*) as cnt from cj_a, cj_b;
→ [{"cnt":6}]

-- Two-table comma list with WHERE join condition
select cj_a.id, cj_b.id from cj_a, cj_b where cj_a.id = cj_b.id - 9 order by cj_a.id;
→ [{"id":1,"id:1":10}]

-- Three-table comma list with chained WHERE
create table cj_c (id integer primary key, vc text);
insert into cj_c values (100, 'c1'), (200, 'c2'), (300, 'c3');

select cj_a.id, cj_b.id, cj_c.id
  from cj_a, cj_b, cj_c
  where cj_a.id = cj_b.id - 9 and cj_b.id = cj_c.id - 90
  order by cj_a.id;
→ [{"id":1,"id:1":10,"id:2":100}]

-- Comma list with WHERE-clause filter only on one table
select cj_a.id, cj_b.id
  from cj_a, cj_b
  where cj_a.id = 1
  order by cj_b.id;
→ [{"id":1,"id:1":10},{"id":1,"id:1":20},{"id":1,"id:1":30}]

-- Mixing comma and explicit JOIN
select cj_a.id, cj_b.id, cj_c.id
  from cj_a, cj_b join cj_c on cj_b.id = cj_c.id - 90
  where cj_a.id = 2
  order by cj_b.id;
→ [{"id":2,"id:1":10,"id:2":100},{"id":2,"id:1":20,"id:2":200},{"id":2,"id:1":30,"id:2":300}]

drop table cj_a;
drop table cj_b;
drop table cj_c;
