-- adapted from SQLite test/bind.test
-- Bind parameter syntax and binding semantics across statement types.
-- Quereus parameter forms: `?` (positional), `:name`, `:N` (numeric named),
-- `$name`, `$N` (numeric named).  `@name` and `?N` are NOT supported.

create table bp (id integer primary key, val integer, name text);
insert into bp values (1, 10, 'alpha'), (2, 20, 'beta'), (3, 30, 'gamma'), (4, null, 'delta');

-- ===================================
-- Positional `?` in basic SELECT
-- ===================================

-- params: [1]
select val from bp where id = ?;
→ [{"val":10}]

-- Two positional parameters, both bound from one params array
-- params: [1, 25]
select id from bp where id = ? or val > ?;
→ [{"id":1},{"id":3}]

-- ===================================
-- Named `:name` in basic SELECT
-- ===================================

-- params: {"id": 2}
select val from bp where id = :id;
→ [{"val":20}]

-- params: {"min": 15, "name": "gamma"}
select id from bp where val >= :min and name = :name;
→ [{"id":3}]

-- Same named parameter referenced twice
-- params: {"target": 2}
select id from bp where id = :target or id = :target + 1;
→ [{"id":2},{"id":3}]

-- ===================================
-- Named `$name` in basic SELECT
-- ===================================

-- params: {"id": 3}
select val from bp where id = $id;
→ [{"val":30}]

-- ===================================
-- Numeric named `:N` and `$N`
-- ===================================

-- params: {"1": 1}
select val from bp where id = :1;
→ [{"val":10}]

-- params: {"1": 2}
select val from bp where id = $1;
→ [{"val":20}]

-- ===================================
-- Parameter type variation
-- ===================================

-- Integer
-- params: [10]
select id from bp where val = ?;
→ [{"id":1}]

-- Real
-- params: [20.0]
select id from bp where val = ?;
→ [{"id":2}]

-- Text
-- params: ["alpha"]
select id from bp where name = ?;
→ [{"id":1}]

-- NULL
-- params: [null]
select id from bp where val is ?;
→ [{"id":4}]

-- ===================================
-- Parameter in INSERT / UPDATE / DELETE
-- ===================================

-- params: [5, 50, "epsilon"]
insert into bp (id, val, name) values (?, ?, ?);
-- run

select val, name from bp where id = 5;
→ [{"val":50,"name":"epsilon"}]

-- params: [99, 5]
update bp set val = ? where id = ?;
-- run

select val from bp where id = 5;
→ [{"val":99}]

-- params: [5]
delete from bp where id = ?;
-- run

select count(*) as cnt from bp where id = 5;
→ [{"cnt":0}]

-- ===================================
-- Parameter in expression contexts
-- ===================================

-- Arithmetic
-- params: [1, 100]
select val + ? as boosted from bp where id = ?;
→ [{"boosted":null}]

-- Function call
-- params: ["alp"]
select id from bp where name like ? || '%';
→ [{"id":1}]

-- CASE expression
-- params: [2]
select case when id = ? then 'match' else 'miss' end as r from bp order by id;
→ [{"r":"miss"},{"r":"match"},{"r":"miss"},{"r":"miss"}]

-- IN list with multiple parameters
-- params: [1, 3]
select id from bp where id in (?, ?) order by id;
→ [{"id":1},{"id":3}]

-- ===================================
-- Parameter in LIMIT / OFFSET
-- ===================================

-- params: [2]
select id from bp order by id limit ?;
→ [{"id":1},{"id":2}]

-- params: [2, 1]
select id from bp order by id limit ? offset ?;
→ [{"id":2},{"id":3}]

-- ===================================
-- Repeated execution with different parameter values
-- ===================================
-- Same prepared shape, different bind values — verifies parameters are
-- not constant-folded into the plan.

-- params: [1]
select val from bp where id = ?;
→ [{"val":10}]

-- params: [2]
select val from bp where id = ?;
→ [{"val":20}]

-- params: [99]
select val from bp where id = ?;
→ []

-- ===================================
-- Cleanup
-- ===================================

drop table bp;
