-- Window Function Tests
-- Tests for SQL window functions with OVER clauses

-- Setup test data
CREATE TABLE sales (
    id INTEGER PRIMARY KEY,
    product TEXT,
    region TEXT,
    amount NUMERIC
);

INSERT INTO sales VALUES
    (1, 'Widget', 'North', 100.50),
    (2, 'Gadget', 'North', 75.25),
    (3, 'Widget', 'South', 120.75),
    (4, 'Gadget', 'South', 90.00),
    (5, 'Widget', 'North', 85.50),
    (6, 'Gadget', 'West', 110.25);

-- Basic ROW_NUMBER() without partitioning
SELECT id, product, ROW_NUMBER() OVER (ORDER BY id) as rn
FROM sales ORDER BY id;
→ [{"id":1,"product":"Widget","rn":1},{"id":2,"product":"Gadget","rn":2},{"id":3,"product":"Widget","rn":3},{"id":4,"product":"Gadget","rn":4},{"id":5,"product":"Widget","rn":5},{"id":6,"product":"Gadget","rn":6}]

-- ROW_NUMBER() with PARTITION BY
SELECT product, region, amount, ROW_NUMBER() OVER (PARTITION BY product ORDER BY amount) as rn
FROM sales ORDER BY product, amount;
→ [{"product":"Gadget","region":"North","amount":75.25,"rn":1},{"product":"Gadget","region":"South","amount":90.00,"rn":2},{"product":"Gadget","region":"West","amount":110.25,"rn":3},{"product":"Widget","region":"North","amount":85.50,"rn":1},{"product":"Widget","region":"North","amount":100.50,"rn":2},{"product":"Widget","region":"South","amount":120.75,"rn":3}]

-- Test RANK() function
SELECT product, amount, RANK() OVER (PARTITION BY product ORDER BY amount) as rnk
FROM sales ORDER BY product, amount;
→ [{"product":"Gadget","amount":75.25,"rnk":1},{"product":"Gadget","amount":90.00,"rnk":2},{"product":"Gadget","amount":110.25,"rnk":3},{"product":"Widget","amount":85.50,"rnk":1},{"product":"Widget","amount":100.50,"rnk":2},{"product":"Widget","amount":120.75,"rnk":3}]

-- Test DENSE_RANK() function
SELECT product, amount, DENSE_RANK() OVER (PARTITION BY product ORDER BY amount) as dense_rnk
FROM sales ORDER BY product, amount;
→ [{"product":"Gadget","amount":75.25,"dense_rnk":1},{"product":"Gadget","amount":90.00,"dense_rnk":2},{"product":"Gadget","amount":110.25,"dense_rnk":3},{"product":"Widget","amount":85.50,"dense_rnk":1},{"product":"Widget","amount":100.50,"dense_rnk":2},{"product":"Widget","amount":120.75,"dense_rnk":3}]

-- Test SUM() OVER for running totals
SELECT product, amount, SUM(amount) OVER (PARTITION BY product ORDER BY id ROWS UNBOUNDED PRECEDING) as running_sum
FROM sales ORDER BY product, id;
→ [{"product":"Gadget","amount":75.25,"running_sum":75.25},{"product":"Gadget","amount":90.00,"running_sum":165.25},{"product":"Gadget","amount":110.25,"running_sum":275.50},{"product":"Widget","amount":100.50,"running_sum":100.50},{"product":"Widget","amount":120.75,"running_sum":221.25},{"product":"Widget","amount":85.50,"running_sum":306.75}]

-- Test COUNT() OVER for row counting
SELECT region, product, COUNT(*) OVER (PARTITION BY region ORDER BY id ROWS UNBOUNDED PRECEDING) as cumulative_count
FROM sales ORDER BY region, id;
→ [{"region":"North","product":"Widget","cumulative_count":1},{"region":"North","product":"Gadget","cumulative_count":2},{"region":"North","product":"Widget","cumulative_count":3},{"region":"South","product":"Widget","cumulative_count":1},{"region":"South","product":"Gadget","cumulative_count":2},{"region":"West","product":"Gadget","cumulative_count":1}]

-- Test AVG() OVER for running averages
SELECT product, amount, AVG(amount) OVER (PARTITION BY product ORDER BY id ROWS UNBOUNDED PRECEDING) as running_avg
FROM sales ORDER BY product, id;
→ [{"product":"Gadget","amount":75.25,"running_avg":75.25},{"product":"Gadget","amount":90.00,"running_avg":82.625},{"product":"Gadget","amount":110.25,"running_avg":91.83333333333333},{"product":"Widget","amount":100.50,"running_avg":100.50},{"product":"Widget","amount":120.75,"running_avg":110.625},{"product":"Widget","amount":85.50,"running_avg":102.25}]

-- Test multiple window functions in same query
SELECT
    product,
    region,
    amount,
    ROW_NUMBER() OVER (ORDER BY amount DESC) as overall_rank,
    ROW_NUMBER() OVER (PARTITION BY product ORDER BY amount DESC) as product_rank,
    SUM(amount) OVER (PARTITION BY product) as product_total
FROM sales ORDER BY amount DESC;
→ [{"product":"Widget","region":"South","amount":120.75,"overall_rank":1,"product_rank":1,"product_total":306.75},{"product":"Gadget","region":"West","amount":110.25,"overall_rank":2,"product_rank":1,"product_total":275.50},{"product":"Widget","region":"North","amount":100.50,"overall_rank":3,"product_rank":2,"product_total":306.75},{"product":"Gadget","region":"South","amount":90.00,"overall_rank":4,"product_rank":2,"product_total":275.50},{"product":"Widget","region":"North","amount":85.50,"overall_rank":5,"product_rank":3,"product_total":306.75},{"product":"Gadget","region":"North","amount":75.25,"overall_rank":6,"product_rank":3,"product_total":275.50}]

-- Test window functions with different frame specifications
SELECT id, amount, SUM(amount) OVER (ORDER BY id ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING) as windowed_sum
FROM sales ORDER BY id;
→ [{"id":1,"amount":100.50,"windowed_sum":175.75},{"id":2,"amount":75.25,"windowed_sum":296.50},{"id":3,"amount":120.75,"windowed_sum":286.00},{"id":4,"amount":90.00,"windowed_sum":296.25},{"id":5,"amount":85.50,"windowed_sum":285.75},{"id":6,"amount":110.25,"windowed_sum":195.75}]

-- Test window frames with non-1 literal offsets
SELECT id, amount, SUM(amount) OVER (ORDER BY id ROWS BETWEEN 2 PRECEDING AND 1 FOLLOWING) as windowed_sum
FROM sales ORDER BY id;
→ [{"id":1,"amount":100.50,"windowed_sum":175.75},{"id":2,"amount":75.25,"windowed_sum":296.50},{"id":3,"amount":120.75,"windowed_sum":386.50},{"id":4,"amount":90.00,"windowed_sum":371.50},{"id":5,"amount":85.50,"windowed_sum":406.50},{"id":6,"amount":110.25,"windowed_sum":285.75}]

-- Test multiple window functions with same OVER clause
SELECT product, amount,
       ROW_NUMBER() OVER (PARTITION BY product ORDER BY amount) as rn,
       RANK() OVER (PARTITION BY product ORDER BY amount) as rnk,
       COUNT(*) OVER (PARTITION BY product ORDER BY amount ROWS UNBOUNDED PRECEDING) as cnt
FROM sales ORDER BY product, amount;
→ [{"product":"Gadget","amount":75.25,"rn":1,"rnk":1,"cnt":1},{"product":"Gadget","amount":90.00,"rn":2,"rnk":2,"cnt":2},{"product":"Gadget","amount":110.25,"rn":3,"rnk":3,"cnt":3},{"product":"Widget","amount":85.50,"rn":1,"rnk":1,"cnt":1},{"product":"Widget","amount":100.50,"rn":2,"rnk":2,"cnt":2},{"product":"Widget","amount":120.75,"rn":3,"rnk":3,"cnt":3}]

-- Edge case: Window function with NULL handling
CREATE TABLE sales_with_nulls (
    id INTEGER PRIMARY KEY,
    product TEXT,
    amount NUMERIC NULL
);

INSERT INTO sales_with_nulls VALUES
    (1, 'Widget', 100.00),
    (2, 'Widget', NULL),
    (3, 'Gadget', 75.00),
    (4, 'Widget', 120.00),
    (5, 'Gadget', NULL);

SELECT product, amount, ROW_NUMBER() OVER (PARTITION BY product ORDER BY amount NULLS LAST) as rn
FROM sales_with_nulls ORDER BY product, COALESCE(amount, 999999);
→ [{"product":"Gadget","amount":75.00,"rn":1},{"product":"Gadget","amount":null,"rn":2},{"product":"Widget","amount":100.00,"rn":1},{"product":"Widget","amount":120.00,"rn":2},{"product":"Widget","amount":null,"rn":3}]

-- Test aggregate window functions with NULLs
SELECT product, amount,
       COUNT(*) OVER (PARTITION BY product) as total_rows,
       COUNT(amount) OVER (PARTITION BY product) as non_null_amounts,
       SUM(amount) OVER (PARTITION BY product) as total_amount
FROM sales_with_nulls ORDER BY product, COALESCE(amount, 999999);
→ [{"product":"Gadget","amount":75.00,"total_rows":2,"non_null_amounts":1,"total_amount":75.00},{"product":"Gadget","amount":null,"total_rows":2,"non_null_amounts":1,"total_amount":75.00},{"product":"Widget","amount":100.00,"total_rows":3,"non_null_amounts":2,"total_amount":220.00},{"product":"Widget","amount":120.00,"total_rows":3,"non_null_amounts":2,"total_amount":220.00},{"product":"Widget","amount":null,"total_rows":3,"non_null_amounts":2,"total_amount":220.00}]

DROP TABLE sales;
DROP TABLE sales_with_nulls;

-- Window Function Frame Equivalence Tests
CREATE TABLE frame_test (id INTEGER PRIMARY KEY, value INTEGER, grp INTEGER);
INSERT INTO frame_test VALUES
(1, 10, 1), (2, 20, 1), (3, 30, 1),
(4, 15, 2), (5, 25, 2), (6, 35, 2);

-- Test equivalent window frame specifications produce same results
SELECT value, grp,
       SUM(value) OVER (PARTITION BY grp ORDER BY value ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as running_sum
FROM frame_test ORDER BY grp, value;
→ [{"value":10,"grp":1,"running_sum":10},{"value":20,"grp":1,"running_sum":30},{"value":30,"grp":1,"running_sum":60},{"value":15,"grp":2,"running_sum":15},{"value":25,"grp":2,"running_sum":40},{"value":35,"grp":2,"running_sum":75}]

SELECT value, grp,
       SUM(value) OVER (PARTITION BY grp ORDER BY value ROWS UNBOUNDED PRECEDING) as running_sum
FROM frame_test ORDER BY grp, value;
→ [{"value":10,"grp":1,"running_sum":10},{"value":20,"grp":1,"running_sum":30},{"value":30,"grp":1,"running_sum":60},{"value":15,"grp":2,"running_sum":15},{"value":25,"grp":2,"running_sum":40},{"value":35,"grp":2,"running_sum":75}]

-- Test different but equivalent frame specifications for COUNT
SELECT value, grp,
       COUNT(*) OVER (PARTITION BY grp ORDER BY value ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as running_count
FROM frame_test ORDER BY grp, value;
→ [{"value":10,"grp":1,"running_count":1},{"value":20,"grp":1,"running_count":2},{"value":30,"grp":1,"running_count":3},{"value":15,"grp":2,"running_count":1},{"value":25,"grp":2,"running_count":2},{"value":35,"grp":2,"running_count":3}]

SELECT value, grp,
       COUNT(*) OVER (PARTITION BY grp ORDER BY value ROWS UNBOUNDED PRECEDING) as running_count
FROM frame_test ORDER BY grp, value;
→ [{"value":10,"grp":1,"running_count":1},{"value":20,"grp":1,"running_count":2},{"value":30,"grp":1,"running_count":3},{"value":15,"grp":2,"running_count":1},{"value":25,"grp":2,"running_count":2},{"value":35,"grp":2,"running_count":3}]

DROP TABLE frame_test;

-- =============================================================================
-- Window PARTITION BY with collation tests
-- =============================================================================

-- NOCASE collation: PARTITION BY should group case-insensitively
CREATE TABLE win_nocase (
    id INTEGER PRIMARY KEY,
    category TEXT COLLATE NOCASE,
    val INTEGER
);

INSERT INTO win_nocase VALUES
    (1, 'Alpha', 10),
    (2, 'ALPHA', 20),
    (3, 'alpha', 30),
    (4, 'Beta', 40),
    (5, 'BETA', 50);

-- All 'alpha' variants should be in the same partition (3 rows), 'beta' variants together (2 rows)
SELECT id, category, val,
       ROW_NUMBER() OVER (PARTITION BY category ORDER BY id) as rn,
       COUNT(*) OVER (PARTITION BY category) as partition_size
FROM win_nocase ORDER BY id;
→ [{"id":1,"category":"Alpha","val":10,"rn":1,"partition_size":3},{"id":2,"category":"ALPHA","val":20,"rn":2,"partition_size":3},{"id":3,"category":"alpha","val":30,"rn":3,"partition_size":3},{"id":4,"category":"Beta","val":40,"rn":1,"partition_size":2},{"id":5,"category":"BETA","val":50,"rn":2,"partition_size":2}]

-- SUM within NOCASE partition
SELECT id, category, val,
       SUM(val) OVER (PARTITION BY category) as partition_total
FROM win_nocase ORDER BY id;
→ [{"id":1,"category":"Alpha","val":10,"partition_total":60},{"id":2,"category":"ALPHA","val":20,"partition_total":60},{"id":3,"category":"alpha","val":30,"partition_total":60},{"id":4,"category":"Beta","val":40,"partition_total":90},{"id":5,"category":"BETA","val":50,"partition_total":90}]

-- DENSE_RANK with NOCASE ORDER BY
CREATE TABLE win_rank_nocase (
    id INTEGER PRIMARY KEY,
    name TEXT COLLATE NOCASE,
    score INTEGER
);

INSERT INTO win_rank_nocase VALUES
    (1, 'Alice', 100),
    (2, 'ALICE', 100),
    (3, 'Bob', 90),
    (4, 'Charlie', 80);

-- 'Alice' and 'ALICE' should be considered equal for ranking under NOCASE
SELECT id, name, score,
       DENSE_RANK() OVER (ORDER BY name) as drnk
FROM win_rank_nocase ORDER BY id;
→ [{"id":1,"name":"Alice","score":100,"drnk":1},{"id":2,"name":"ALICE","score":100,"drnk":1},{"id":3,"name":"Bob","score":90,"drnk":2},{"id":4,"name":"Charlie","score":80,"drnk":3}]

-- RANK with NOCASE ORDER BY
SELECT id, name, score,
       RANK() OVER (ORDER BY name) as rnk
FROM win_rank_nocase ORDER BY id;
→ [{"id":1,"name":"Alice","score":100,"rnk":1},{"id":2,"name":"ALICE","score":100,"rnk":1},{"id":3,"name":"Bob","score":90,"rnk":3},{"id":4,"name":"Charlie","score":80,"rnk":4}]

-- NULL in PARTITION BY: NULLs should group together
CREATE TABLE win_null_part (
    id INTEGER PRIMARY KEY,
    grp TEXT NULL,
    val INTEGER
);

INSERT INTO win_null_part VALUES
    (1, NULL, 10),
    (2, NULL, 20),
    (3, 'A', 30),
    (4, 'A', 40);

SELECT id, grp, val,
       COUNT(*) OVER (PARTITION BY grp) as partition_size,
       SUM(val) OVER (PARTITION BY grp) as partition_total
FROM win_null_part ORDER BY id;
→ [{"id":1,"grp":null,"val":10,"partition_size":2,"partition_total":30},{"id":2,"grp":null,"val":20,"partition_size":2,"partition_total":30},{"id":3,"grp":"A","val":30,"partition_size":2,"partition_total":70},{"id":4,"grp":"A","val":40,"partition_size":2,"partition_total":70}]

DROP TABLE win_nocase;
DROP TABLE win_rank_nocase;
DROP TABLE win_null_part;

-- =============================================================================
-- LAG / LEAD tests
-- =============================================================================

CREATE TABLE nav_test (id INTEGER PRIMARY KEY, val INTEGER, grp TEXT);
INSERT INTO nav_test VALUES
(1, 10, 'A'), (2, 20, 'A'), (3, 30, 'A'),
(4, 100, 'B'), (5, 200, 'B');

-- Basic LAG (default offset = 1)
SELECT id, val, LAG(val) OVER (ORDER BY id) as prev_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"prev_val":null},{"id":2,"val":20,"prev_val":10},{"id":3,"val":30,"prev_val":20},{"id":4,"val":100,"prev_val":30},{"id":5,"val":200,"prev_val":100}]

-- Basic LEAD (default offset = 1)
SELECT id, val, LEAD(val) OVER (ORDER BY id) as next_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"next_val":20},{"id":2,"val":20,"next_val":30},{"id":3,"val":30,"next_val":100},{"id":4,"val":100,"next_val":200},{"id":5,"val":200,"next_val":null}]

-- LAG with explicit offset
SELECT id, val, LAG(val, 2) OVER (ORDER BY id) as prev2_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"prev2_val":null},{"id":2,"val":20,"prev2_val":null},{"id":3,"val":30,"prev2_val":10},{"id":4,"val":100,"prev2_val":20},{"id":5,"val":200,"prev2_val":30}]

-- LEAD with explicit offset and default
SELECT id, val, LEAD(val, 1, -1) OVER (ORDER BY id) as next_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"next_val":20},{"id":2,"val":20,"next_val":30},{"id":3,"val":30,"next_val":100},{"id":4,"val":100,"next_val":200},{"id":5,"val":200,"next_val":-1}]

-- LAG with default value
SELECT id, val, LAG(val, 1, 0) OVER (ORDER BY id) as prev_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"prev_val":0},{"id":2,"val":20,"prev_val":10},{"id":3,"val":30,"prev_val":20},{"id":4,"val":100,"prev_val":30},{"id":5,"val":200,"prev_val":100}]

-- LAG/LEAD with PARTITION BY (should not cross partition boundaries)
SELECT id, val, grp,
       LAG(val) OVER (PARTITION BY grp ORDER BY id) as prev_val,
       LEAD(val) OVER (PARTITION BY grp ORDER BY id) as next_val
FROM nav_test ORDER BY id;
→ [{"id":1,"val":10,"grp":"A","prev_val":null,"next_val":20},{"id":2,"val":20,"grp":"A","prev_val":10,"next_val":30},{"id":3,"val":30,"grp":"A","prev_val":20,"next_val":null},{"id":4,"val":100,"grp":"B","prev_val":null,"next_val":200},{"id":5,"val":200,"grp":"B","prev_val":100,"next_val":null}]

DROP TABLE nav_test;

-- =============================================================================
-- FIRST_VALUE / LAST_VALUE tests
-- =============================================================================

CREATE TABLE fv_test (id INTEGER PRIMARY KEY, val INTEGER, grp TEXT);
INSERT INTO fv_test VALUES
(1, 10, 'A'), (2, 20, 'A'), (3, 30, 'A'),
(4, 100, 'B'), (5, 200, 'B');

-- FIRST_VALUE over entire partition
SELECT id, val, grp,
       FIRST_VALUE(val) OVER (PARTITION BY grp ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) as first_val
FROM fv_test ORDER BY id;
→ [{"id":1,"val":10,"grp":"A","first_val":10},{"id":2,"val":20,"grp":"A","first_val":10},{"id":3,"val":30,"grp":"A","first_val":10},{"id":4,"val":100,"grp":"B","first_val":100},{"id":5,"val":200,"grp":"B","first_val":100}]

-- LAST_VALUE over entire partition (must use explicit frame)
SELECT id, val, grp,
       LAST_VALUE(val) OVER (PARTITION BY grp ORDER BY id ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) as last_val
FROM fv_test ORDER BY id;
→ [{"id":1,"val":10,"grp":"A","last_val":30},{"id":2,"val":20,"grp":"A","last_val":30},{"id":3,"val":30,"grp":"A","last_val":30},{"id":4,"val":100,"grp":"B","last_val":200},{"id":5,"val":200,"grp":"B","last_val":200}]

-- LAST_VALUE with default frame (ORDER BY present, no explicit frame = up to current row)
SELECT id, val,
       LAST_VALUE(val) OVER (ORDER BY id) as last_val
FROM fv_test ORDER BY id;
→ [{"id":1,"val":10,"last_val":10},{"id":2,"val":20,"last_val":20},{"id":3,"val":30,"last_val":30},{"id":4,"val":100,"last_val":100},{"id":5,"val":200,"last_val":200}]

-- FIRST_VALUE without ORDER BY (entire partition)
SELECT id, val, grp,
       FIRST_VALUE(val) OVER (PARTITION BY grp) as first_val
FROM fv_test ORDER BY id;
→ [{"id":1,"val":10,"grp":"A","first_val":10},{"id":2,"val":20,"grp":"A","first_val":10},{"id":3,"val":30,"grp":"A","first_val":10},{"id":4,"val":100,"grp":"B","first_val":100},{"id":5,"val":200,"grp":"B","first_val":100}]

DROP TABLE fv_test;

-- =============================================================================
-- PERCENT_RANK / CUME_DIST tests
-- =============================================================================

CREATE TABLE stat_test (id INTEGER PRIMARY KEY, val INTEGER);
INSERT INTO stat_test VALUES (1, 10), (2, 20), (3, 20), (4, 30), (5, 40);

-- PERCENT_RANK: (rank - 1) / (rows - 1)
SELECT id, val, PERCENT_RANK() OVER (ORDER BY val) as pct_rank
FROM stat_test ORDER BY id;
→ [{"id":1,"val":10,"pct_rank":0},{"id":2,"val":20,"pct_rank":0.25},{"id":3,"val":20,"pct_rank":0.25},{"id":4,"val":30,"pct_rank":0.75},{"id":5,"val":40,"pct_rank":1}]

-- CUME_DIST: (count of rows <= current) / total
SELECT id, val, CUME_DIST() OVER (ORDER BY val) as cume
FROM stat_test ORDER BY id;
→ [{"id":1,"val":10,"cume":0.2},{"id":2,"val":20,"cume":0.6},{"id":3,"val":20,"cume":0.6},{"id":4,"val":30,"cume":0.8},{"id":5,"val":40,"cume":1}]

-- Single-row partition: PERCENT_RANK = 0, CUME_DIST = 1
SELECT val, PERCENT_RANK() OVER (PARTITION BY val ORDER BY val) as pct_rank,
       CUME_DIST() OVER (PARTITION BY val ORDER BY val) as cume
FROM stat_test WHERE val = 10;
→ [{"val":10,"pct_rank":0,"cume":1}]

DROP TABLE stat_test;

-- =============================================================================
-- NTILE tests
-- =============================================================================

CREATE TABLE ntile_test (id INTEGER PRIMARY KEY, val INTEGER);
INSERT INTO ntile_test VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

-- NTILE(2): 3 rows in bucket 1, 2 rows in bucket 2
SELECT id, val, NTILE(2) OVER (ORDER BY id) as bucket
FROM ntile_test ORDER BY id;
→ [{"id":1,"val":10,"bucket":1},{"id":2,"val":20,"bucket":1},{"id":3,"val":30,"bucket":1},{"id":4,"val":40,"bucket":2},{"id":5,"val":50,"bucket":2}]

-- NTILE(3): 2 rows in bucket 1, 2 in bucket 2, 1 in bucket 3
SELECT id, val, NTILE(3) OVER (ORDER BY id) as bucket
FROM ntile_test ORDER BY id;
→ [{"id":1,"val":10,"bucket":1},{"id":2,"val":20,"bucket":1},{"id":3,"val":30,"bucket":2},{"id":4,"val":40,"bucket":2},{"id":5,"val":50,"bucket":3}]

-- NTILE(5): 1 row per bucket
SELECT id, val, NTILE(5) OVER (ORDER BY id) as bucket
FROM ntile_test ORDER BY id;
→ [{"id":1,"val":10,"bucket":1},{"id":2,"val":20,"bucket":2},{"id":3,"val":30,"bucket":3},{"id":4,"val":40,"bucket":4},{"id":5,"val":50,"bucket":5}]

DROP TABLE ntile_test;

-- =============================================================================
-- RANGE BETWEEN tests (value-based window frames)
-- =============================================================================

CREATE TABLE range_test (id INTEGER PRIMARY KEY, val INTEGER, grp TEXT);
INSERT INTO range_test VALUES
(1, 10, 'A'), (2, 20, 'A'), (3, 20, 'A'), (4, 30, 'A'), (5, 50, 'A');

-- RANGE CURRENT ROW: includes all peer rows (same ORDER BY value)
SELECT id, val,
       COUNT(*) OVER (ORDER BY val RANGE CURRENT ROW) as peer_count
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"peer_count":1},{"id":2,"val":20,"peer_count":2},{"id":3,"val":20,"peer_count":2},{"id":4,"val":30,"peer_count":1},{"id":5,"val":50,"peer_count":1}]

-- RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW (default frame with ORDER BY)
-- Should include all peers at current value
SELECT id, val,
       SUM(val) OVER (ORDER BY val RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) as running_sum
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"running_sum":10},{"id":2,"val":20,"running_sum":50},{"id":3,"val":20,"running_sum":50},{"id":4,"val":30,"running_sum":80},{"id":5,"val":50,"running_sum":130}]

-- Default frame (ORDER BY present) should be RANGE UNBOUNDED PRECEDING AND CURRENT ROW
-- including peers
SELECT id, val,
       SUM(val) OVER (ORDER BY val) as running_sum
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"running_sum":10},{"id":2,"val":20,"running_sum":50},{"id":3,"val":20,"running_sum":50},{"id":4,"val":30,"running_sum":80},{"id":5,"val":50,"running_sum":130}]

-- RANGE N PRECEDING: value-based offset
SELECT id, val,
       SUM(val) OVER (ORDER BY val RANGE BETWEEN 10 PRECEDING AND CURRENT ROW) as range_sum
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"range_sum":10},{"id":2,"val":20,"range_sum":50},{"id":3,"val":20,"range_sum":50},{"id":4,"val":30,"range_sum":70},{"id":5,"val":50,"range_sum":50}]

-- RANGE BETWEEN N PRECEDING AND N FOLLOWING
-- val=10: [5,15] → 10; val=20: [15,25] → 20+20=40; val=30: [25,35] → 30; val=50: [45,55] → 50
SELECT id, val,
       SUM(val) OVER (ORDER BY val RANGE BETWEEN 5 PRECEDING AND 5 FOLLOWING) as range_sum
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"range_sum":10},{"id":2,"val":20,"range_sum":40},{"id":3,"val":20,"range_sum":40},{"id":4,"val":30,"range_sum":30},{"id":5,"val":50,"range_sum":50}]

-- RANGE UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING (same as ROWS)
SELECT id, val,
       SUM(val) OVER (ORDER BY val RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) as total
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"total":130},{"id":2,"val":20,"total":130},{"id":3,"val":20,"total":130},{"id":4,"val":30,"total":130},{"id":5,"val":50,"total":130}]

-- FIRST_VALUE/LAST_VALUE with RANGE CURRENT ROW
SELECT id, val,
       FIRST_VALUE(id) OVER (ORDER BY val RANGE CURRENT ROW) as first_peer_id,
       LAST_VALUE(id) OVER (ORDER BY val RANGE CURRENT ROW) as last_peer_id
FROM range_test ORDER BY id;
→ [{"id":1,"val":10,"first_peer_id":1,"last_peer_id":1},{"id":2,"val":20,"first_peer_id":2,"last_peer_id":3},{"id":3,"val":20,"first_peer_id":2,"last_peer_id":3},{"id":4,"val":30,"first_peer_id":4,"last_peer_id":4},{"id":5,"val":50,"first_peer_id":5,"last_peer_id":5}]

DROP TABLE range_test;
