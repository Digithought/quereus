-- like-glob-edges.sqllogic - LIKE / GLOB scenarios beyond 06-builtin_functions and
-- 24-builtin-branches: case-sensitivity invariant, ESCAPE clause, multi-byte chars,
-- BLOB operands, GLOB character classes.
-- adapted from SQLite test/like.test and test/like2.test

-- Quereus LIKE is case-SENSITIVE by design (no PRAGMA case_sensitive_like)
select like('A%', 'apple') as result;
→ [{"result":false}]

select like('a%', 'apple') as result;
→ [{"result":true}]

select like('apple', 'APPLE') as result;
→ [{"result":false}]

-- LIKE with multi-byte UTF-8: `_` should match a single character (code point), not byte
select like('a_b', 'a' || char(228) || 'b') as result;
→ [{"result":true}]

select like('a_b', 'aäb') as result;
→ [{"result":true}]

-- LIKE with non-BMP character (one code point)
select like('_', '😀') as result;
→ [{"result":true}]

-- LIKE on numeric: SQLite coerces; assert observable behavior on a text column
create table like_num (id integer primary key, n integer);
insert into like_num values (1, 1234);
select like('12%', n) from like_num;
→ [{"like('12%', n)":true}]
drop table like_num;

-- LIKE on BLOB: SQLite supports byte-comparison; assert via table column
create table like_blob (id integer primary key, b blob);
insert into like_blob values (1, x'48656c6c6f');
select b like x'48%' from like_blob;
→ [{"b like x'48%'":true}]
drop table like_blob;

-- ESCAPE clause: literal `%` and `_` via backslash
select 'ab%cd' like 'ab\%cd' escape '\' as result;
→ [{"result":true}]

select 'ab_cd' like 'ab\_cd' escape '\' as result;
→ [{"result":true}]

-- ESCAPE clause: an unescaped `%` still acts as wildcard
select 'aXc' like 'a%c' escape '\' as result;
→ [{"result":true}]

-- ESCAPE clause: escaped `_` is literal, NOT a single-char wildcard
select 'aXb' like 'a\_b' escape '\' as result;
→ [{"result":false}]

-- ESCAPE clause: escaping the escape char itself
select 'a\b' like 'a\\b' escape '\' as result;
→ [{"result":true}]

-- GLOB is also case-sensitive
select glob('ABC*', 'abcdef') as result;
→ [{"result":false}]

select glob('abc*', 'abcdef') as result;
→ [{"result":true}]

-- GLOB character class: any of the listed chars
select glob('[abc]', 'a') as result;
→ [{"result":true}]

select glob('[abc]', 'd') as result;
→ [{"result":false}]

-- GLOB character class: range syntax
select glob('[a-c]', 'b') as result;
→ [{"result":true}]

select glob('[a-c]', 'd') as result;
→ [{"result":false}]

-- GLOB negation with `^`
select glob('[^abc]', 'd') as result;
→ [{"result":true}]

select glob('[^abc]', 'a') as result;
→ [{"result":false}]
