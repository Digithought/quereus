-- adapted from SQLite test/window1.test, test/window2.test, test/window5.test, test/window8.test
-- EXCLUDE clause modifiers: NO OTHERS (default), CURRENT ROW, GROUP, TIES.

create table ex (id integer primary key, val integer);
insert into ex values (1, 10), (2, 10), (3, 20), (4, 30), (5, 30);

-- EXCLUDE NO OTHERS is the default; explicit form should match the implicit one
select id, val,
       sum(val) over (order by val rows between unbounded preceding and unbounded following) as s_default,
       sum(val) over (order by val rows between unbounded preceding and unbounded following exclude no others) as s_explicit
from ex order by id;
→ [{"id":1,"val":10,"s_default":100,"s_explicit":100},{"id":2,"val":10,"s_default":100,"s_explicit":100},{"id":3,"val":20,"s_default":100,"s_explicit":100},{"id":4,"val":30,"s_default":100,"s_explicit":100},{"id":5,"val":30,"s_default":100,"s_explicit":100}]

-- EXCLUDE CURRENT ROW: drop the current row from the frame, keep all peers
select id, val,
       sum(val) over (order by id rows between unbounded preceding and unbounded following exclude current row) as s
from ex order by id;
→ [{"id":1,"val":10,"s":90},{"id":2,"val":10,"s":90},{"id":3,"val":20,"s":80},{"id":4,"val":30,"s":70},{"id":5,"val":30,"s":70}]

-- EXCLUDE CURRENT ROW with running sum: classic "everyone except me so far"
select id, val,
       sum(val) over (order by id rows between unbounded preceding and current row exclude current row) as others_so_far
from ex order by id;
→ [{"id":1,"val":10,"others_so_far":null},{"id":2,"val":10,"others_so_far":10},{"id":3,"val":20,"others_so_far":20},{"id":4,"val":30,"others_so_far":40},{"id":5,"val":30,"others_so_far":70}]

-- EXCLUDE GROUP: drop the current row AND all its peers (rows with same ORDER BY value)
select id, val,
       sum(val) over (order by val range between unbounded preceding and unbounded following exclude group) as s
from ex order by id;
→ [{"id":1,"val":10,"s":80},{"id":2,"val":10,"s":80},{"id":3,"val":20,"s":80},{"id":4,"val":30,"s":40},{"id":5,"val":30,"s":40}]

-- EXCLUDE TIES: keep the current row, drop only the other peers
select id, val,
       sum(val) over (order by val range between unbounded preceding and unbounded following exclude ties) as s
from ex order by id;
→ [{"id":1,"val":10,"s":90},{"id":2,"val":10,"s":90},{"id":3,"val":20,"s":100},{"id":4,"val":30,"s":70},{"id":5,"val":30,"s":70}]

-- count(*) with each EXCLUDE mode over the whole partition (5 rows, 3 distinct values)
select id, val,
       count(*) over (order by val range between unbounded preceding and unbounded following) as c_no,
       count(*) over (order by val range between unbounded preceding and unbounded following exclude current row) as c_cur,
       count(*) over (order by val range between unbounded preceding and unbounded following exclude group) as c_grp,
       count(*) over (order by val range between unbounded preceding and unbounded following exclude ties) as c_ties
from ex order by id;
→ [{"id":1,"val":10,"c_no":5,"c_cur":4,"c_grp":3,"c_ties":4},{"id":2,"val":10,"c_no":5,"c_cur":4,"c_grp":3,"c_ties":4},{"id":3,"val":20,"c_no":5,"c_cur":4,"c_grp":4,"c_ties":5},{"id":4,"val":30,"c_no":5,"c_cur":4,"c_grp":3,"c_ties":4},{"id":5,"val":30,"c_no":5,"c_cur":4,"c_grp":3,"c_ties":4}]

-- EXCLUDE combined with GROUPS frame
select id, val,
       sum(val) over (order by val groups between unbounded preceding and unbounded following exclude current row) as s
from ex order by id;
→ [{"id":1,"val":10,"s":90},{"id":2,"val":10,"s":90},{"id":3,"val":20,"s":80},{"id":4,"val":30,"s":70},{"id":5,"val":30,"s":70}]

drop table ex;
