-- distilled from SQLite test/conflict.test (replace/or-clauses surface);
-- replace.test does not exist upstream, but the ticket calls out
-- "INSERT OR REPLACE / OR IGNORE / OR ABORT / OR FAIL / OR ROLLBACK —
--  Quereus's conflict-resolution surface may differ. Pin it down per clause."
-- Existing fixtures cover OR IGNORE / OR REPLACE on UNIQUE (102) and NOT NULL (43.1);
-- this fills in the REPLACE-INTO keyword form, multi-row REPLACE, REPLACE+RETURNING,
-- UPDATE OR REPLACE on UNIQUE, and OR FAIL / OR ROLLBACK / OR ABORT semantics
-- with respect to surrounding transactional state.

-- ===================================
-- 1. REPLACE INTO keyword — equivalent to INSERT OR REPLACE
-- ===================================

create table rk (id integer primary key, email text unique, name text);
insert into rk values (1, 'a@x', 'Alice'), (2, 'b@x', 'Bob');

-- REPLACE INTO on PK conflict deletes the old row and inserts the new
replace into rk values (1, 'a@x', 'Alice2');
select id, email, name from rk order by id;
→ [{"id":1,"email":"a@x","name":"Alice2"},{"id":2,"email":"b@x","name":"Bob"}]

-- REPLACE INTO with no conflict acts as plain INSERT
replace into rk values (3, 'c@x', 'Carol');
select id, name from rk order by id;
→ [{"id":1,"name":"Alice2"},{"id":2,"name":"Bob"},{"id":3,"name":"Carol"}]

drop table rk;

-- ===================================
-- 2. REPLACE multi-row VALUES — atomic per-row conflict resolution
-- ===================================

create table rm (id integer primary key, name text unique);
insert into rm values (1, 'Alice'), (2, 'Bob');

replace into rm values (1, 'Alice-New'), (3, 'Carol');

select id, name from rm order by id;
→ [{"id":1,"name":"Alice-New"},{"id":2,"name":"Bob"},{"id":3,"name":"Carol"}]

drop table rm;

-- ===================================
-- 3. REPLACE that resolves multiple existing rows via UNIQUE conflict on different cols
-- ===================================

create table rmm (id integer primary key, email text unique, phone text unique);
insert into rmm values (1, 'a@x', '111'), (2, 'b@x', '222');

-- new row conflicts on email with id=1 and phone with id=2 — both old rows are replaced
replace into rmm values (3, 'a@x', '222');
select id from rmm order by id;
→ [{"id":3}]

drop table rmm;

-- ===================================
-- 4. REPLACE INTO with RETURNING
-- ===================================

create table rr (id integer primary key, val text);
insert into rr values (1, 'old');

replace into rr values (1, 'new') returning id, val;
→ [{"id":1,"val":"new"}]

drop table rr;

-- ===================================
-- 5. UPDATE OR REPLACE on UNIQUE conflict — old conflicting row deleted
-- ===================================

create table uor (id integer primary key, code text unique);
insert into uor values (1, 'aaa'), (2, 'bbb');

-- updating id=2's code to 'aaa' would conflict with id=1; OR REPLACE deletes id=1
update or replace uor set code = 'aaa' where id = 2;

select id, code from uor order by id;
→ [{"id":2,"code":"aaa"}]

drop table uor;

-- ===================================
-- 6. INSERT OR ABORT (default) — violation aborts the statement entirely
-- ===================================

create table ab (id integer primary key, val text);
insert into ab values (1, 'a');

-- bulk insert with a duplicate PK in the middle aborts the entire statement
insert or abort into ab values (2, 'b'), (1, 'dup'), (3, 'c');
-- error: PRIMARY KEY

-- nothing should have been inserted
select count(*) as cnt from ab;
→ [{"cnt":1}]

drop table ab;

-- ===================================
-- 7. INSERT OR FAIL — earlier rows in the failing statement remain inserted
-- ===================================

create table fl (id integer primary key, val text);
insert into fl values (5, 'pre');

-- FAIL inserts rows that succeed before the violation, then halts
insert or fail into fl values (1, 'a'), (2, 'b'), (5, 'dup'), (3, 'c');
-- error: PRIMARY KEY

-- rows (1,'a') and (2,'b') should have been inserted; (3,'c') should not
select id, val from fl order by id;
→ [{"id":1,"val":"a"},{"id":2,"val":"b"},{"id":5,"val":"pre"}]

drop table fl;

-- ===================================
-- 8. INSERT OR ROLLBACK — violation rolls back the enclosing transaction
-- ===================================

create table rb (id integer primary key, val text);
insert into rb values (1, 'pre');

begin;
   insert into rb values (10, 'committed_in_tx');
   insert or rollback into rb values (1, 'dup');
   -- error: PRIMARY KEY

-- transaction was rolled back — only the original row remains
select id, val from rb order by id;
→ [{"id":1,"val":"pre"}]

drop table rb;

-- ===================================
-- 9. INSERT OR IGNORE on CHECK constraint — violating row silently skipped
-- ===================================

create table ck (id integer primary key, n integer check (n > 0));
insert into ck values (1, 10);

insert or ignore into ck values (2, -5);
select count(*) as cnt from ck;
→ [{"cnt":1}]

-- valid follow-up insert succeeds
insert or ignore into ck values (3, 30);
select id, n from ck order by id;
→ [{"id":1,"n":10},{"id":3,"n":30}]

drop table ck;

-- ===================================
-- 10. INSERT OR REPLACE on CHECK — REPLACE does NOT mask CHECK violations
-- ===================================

create table ck2 (id integer primary key, n integer check (n > 0));
insert into ck2 values (1, 10);

-- REPLACE relaxes UNIQUE/PK conflicts but CHECK is always abort-only
insert or replace into ck2 values (2, -5);
-- error: CHECK

select count(*) as cnt from ck2;
→ [{"cnt":1}]

drop table ck2;
