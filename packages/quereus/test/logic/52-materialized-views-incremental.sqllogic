-- 52-materialized-views-incremental.sqllogic — incremental materialized views
-- (phase 2, refresh = 'on-commit-incremental'). Source mutations maintain the
-- backing table at COMMIT; no manual refresh required.

-- ===================================
-- 1. Per-row apply — keyed row-preserving body
-- ===================================

create table t (id integer primary key, x integer);
insert into t values (1, 10), (2, 20), (3, 30);
create materialized view mv_row as select id, x + 1 as x1 from t with refresh = 'on-commit-incremental';

-- MV equals the body at create time
select * from mv_row order by id;
→ [{"id":1,"x1":11},{"id":2,"x1":21},{"id":3,"x1":31}]

-- INSERT on the source is reflected at commit, no manual refresh
insert into t values (4, 40);
select * from mv_row order by id;
→ [{"id":1,"x1":11},{"id":2,"x1":21},{"id":3,"x1":31},{"id":4,"x1":41}]

-- UPDATE on the source is reflected
update t set x = 100 where id = 2;
select * from mv_row order by id;
→ [{"id":1,"x1":11},{"id":2,"x1":101},{"id":3,"x1":31},{"id":4,"x1":41}]

-- DELETE on the source is reflected
delete from t where id = 1;
select * from mv_row order by id;
→ [{"id":2,"x1":101},{"id":3,"x1":31},{"id":4,"x1":41}]

-- ===================================
-- 2. Per-group apply — aggregate body
-- ===================================

create table g (id integer primary key, k integer, v integer);
insert into g values (1, 100, 5), (2, 100, 7), (3, 200, 3);
create materialized view mv_grp as select k, sum(v) as sv from g group by k with refresh = 'on-commit-incremental';

select * from mv_grp order by k;
→ [{"k":100,"sv":12},{"k":200,"sv":3}]

-- New row in an existing group recomputes that group
insert into g values (4, 100, 1);
select * from mv_grp order by k;
→ [{"k":100,"sv":13},{"k":200,"sv":3}]

-- New group creates a new MV row
insert into g values (5, 300, 9);
select * from mv_grp order by k;
→ [{"k":100,"sv":13},{"k":200,"sv":3},{"k":300,"sv":9}]

-- Deleting the only row of a group removes the MV row
delete from g where id = 3;
select * from mv_grp order by k;
→ [{"k":100,"sv":13},{"k":300,"sv":9}]

-- ===================================
-- 3. OLD/NEW group transition — UPDATE moves a row between groups
-- ===================================

-- id=4 moves from group 100 → 200: group 100 recomputes (5+7=12), group 200 appears (1)
update g set k = 200 where id = 4;
select * from mv_grp order by k;
→ [{"k":100,"sv":12},{"k":200,"sv":1},{"k":300,"sv":9}]

-- ===================================
-- 4. Manual refresh still works on an incremental MV (resync escape valve)
-- ===================================

refresh materialized view mv_grp;
select * from mv_grp order by k;
→ [{"k":100,"sv":12},{"k":200,"sv":1},{"k":300,"sv":9}]

-- ===================================
-- 5. Cost fallback — a large fraction of changed rows still yields correct state
--    (the kernel demotes per-binding to a full rebuild; result must be correct)
-- ===================================

create table big (id integer primary key, v integer);
insert into big values (1, 1), (2, 1);
create materialized view mv_big as select id, v from big with refresh = 'on-commit-incremental';
-- Insert many rows in one transaction (> fallback ratio of base size) → rebuild path
insert into big values (3, 1), (4, 1), (5, 1), (6, 1), (7, 1), (8, 1), (9, 1), (10, 1);
select sum(v) as total, count(*) as n from mv_big;
→ [{"total":10,"n":10}]

-- ===================================
-- 6. Eligibility gate — a whole-table ('global') source is rejected at create
-- ===================================

create table agg (id integer primary key, v integer);
insert into agg values (1, 10);
create materialized view mv_bad as select count(*) as c from agg with refresh = 'on-commit-incremental';
-- error: on-commit-incremental

-- A manual MV over the same body is fine (no eligibility gate)
create materialized view mv_ok_manual as select count(*) as c from agg;
select * from mv_ok_manual;
→ [{"c":1}]
drop materialized view mv_ok_manual;

-- ===================================
-- 7. Set-operation / recursive-CTE bodies are rejected under incremental refresh
-- ===================================

create materialized view mv_union as select id from t union select id from agg with refresh = 'on-commit-incremental';
-- error: set-operation

create materialized view mv_rec as with recursive r(n) as (select 1 union all select n + 1 from r where n < 3) select n from r with refresh = 'on-commit-incremental';
-- error: recursive

-- ===================================
-- 8. Schema-change invalidation — dropping a source detaches + staleness diagnostic
-- ===================================

create table src (id integer primary key, v integer);
insert into src values (1, 5);
create materialized view mv_src as select id, v from src with refresh = 'on-commit-incremental';
select * from mv_src order by id;
→ [{"id":1,"v":5}]

drop table src;
select * from mv_src;
-- error: stale
drop materialized view mv_src;

-- ===================================
-- 9. Row body with a WHERE filter — a row leaving / entering the predicate
--    via UPDATE must delete / insert its MV row (delete-then-recompute).
-- ===================================

create table tf (id integer primary key, x integer);
insert into tf values (1, 5), (2, -3), (3, 8);
create materialized view mv_filt as select id, x from tf where x > 0 with refresh = 'on-commit-incremental';
select * from mv_filt order by id;
→ [{"id":1,"x":5},{"id":3,"x":8}]

-- Row id=1 leaves the predicate (x>0 → x=-1): its MV row must disappear
update tf set x = -1 where id = 1;
select * from mv_filt order by id;
→ [{"id":3,"x":8}]

-- Row id=2 enters the predicate (x=-3 → x=10): its MV row must appear
update tf set x = 10 where id = 2;
select * from mv_filt order by id;
→ [{"id":2,"x":10},{"id":3,"x":8}]

-- ===================================
-- 10. Nullable group key with NULL rows — NULL-safe residual filter +
--     NULL-valued delete key must maintain the NULL group correctly.
-- ===================================

create table gn (id integer primary key, k integer null, v integer);
insert into gn values (1, null, 5), (2, null, 7), (3, 10, 2);
create materialized view mv_gn as select k, sum(v) as sv from gn group by k with refresh = 'on-commit-incremental';
select * from mv_gn order by k;
→ [{"k":null,"sv":12},{"k":10,"sv":2}]

-- New row in the NULL group recomputes only that group (no duplicate NULL row)
insert into gn values (4, null, 3);
select * from mv_gn order by k;
→ [{"k":null,"sv":15},{"k":10,"sv":2}]

-- Deleting a NULL-group row recomputes the NULL group again
delete from gn where id = 1;
select * from mv_gn order by k;
→ [{"k":null,"sv":10},{"k":10,"sv":2}]

-- ===================================
-- 11. Two incremental MVs over the same source — independent subscriptions
--     both maintained from a single source mutation.
-- ===================================

create table s2 (id integer primary key, x integer);
insert into s2 values (1, 1), (2, 2);
create materialized view mv_a as select id, x from s2 with refresh = 'on-commit-incremental';
create materialized view mv_b as select id, x * 10 as x10 from s2 with refresh = 'on-commit-incremental';
insert into s2 values (3, 3);
select * from mv_a order by id;
→ [{"id":1,"x":1},{"id":2,"x":2},{"id":3,"x":3}]
select * from mv_b order by id;
→ [{"id":1,"x10":10},{"id":2,"x10":20},{"id":3,"x10":30}]

-- ===================================
-- 12. Compound-PK source (multi-column delete key) + multi-column GROUP BY.
-- ===================================

create table cp (a integer, b integer, v integer, primary key (a, b));
insert into cp values (1, 1, 100), (1, 2, 200), (2, 1, 300);
create materialized view mv_cp as select a, b, v from cp with refresh = 'on-commit-incremental';
select * from mv_cp order by a, b;
→ [{"a":1,"b":1,"v":100},{"a":1,"b":2,"v":200},{"a":2,"b":1,"v":300}]

-- Update keyed on the full compound PK
update cp set v = 999 where a = 1 and b = 2;
select * from mv_cp order by a, b;
→ [{"a":1,"b":1,"v":100},{"a":1,"b":2,"v":999},{"a":2,"b":1,"v":300}]

-- Delete keyed on the full compound PK
delete from cp where a = 2 and b = 1;
select * from mv_cp order by a, b;
→ [{"a":1,"b":1,"v":100},{"a":1,"b":2,"v":999}]

create table mc (id integer primary key, g1 integer, g2 integer, v integer);
insert into mc values (1, 1, 1, 10), (2, 1, 2, 20), (3, 1, 1, 5);
create materialized view mv_mc as select g1, g2, sum(v) as sv from mc group by g1, g2 with refresh = 'on-commit-incremental';
select * from mv_mc order by g1, g2;
→ [{"g1":1,"g2":1,"sv":15},{"g1":1,"g2":2,"sv":20}]

-- New row in an existing multi-column group recomputes only that group
insert into mc values (4, 1, 2, 100);
select * from mv_mc order by g1, g2;
→ [{"g1":1,"g2":1,"sv":15},{"g1":1,"g2":2,"sv":120}]

drop materialized view mv_filt;
drop materialized view mv_gn;
drop materialized view mv_a;
drop materialized view mv_b;
drop materialized view mv_cp;
drop materialized view mv_mc;
drop table tf;
drop table gn;
drop table s2;
drop table cp;
drop table mc;

-- Cleanup
drop materialized view mv_row;
drop materialized view mv_grp;
drop materialized view mv_big;
drop table t;
drop table g;
drop table big;
drop table agg;

-- ===================================
-- 13. Cascading MV-over-MV — a linear chain converges in ONE commit.
--     mv2's body reads mv1's backing table; a single source mutation maintains
--     both the same commit (no second commit / manual refresh needed). The
--     manager processes incremental MVs in dependency-topological order and
--     feeds each producer's backing-table write to its dependents via a per-pass
--     delta overlay layered on the change log.
-- ===================================

create table c_t (id integer primary key, x integer);
insert into c_t values (1, 10), (2, 20);
create materialized view c_mv1 as select id, x + 1 as x1 from c_t with refresh = 'on-commit-incremental';
create materialized view c_mv2 as select id, x1 * 10 as x10 from c_mv1 with refresh = 'on-commit-incremental';

-- Both levels materialize at create time
select * from c_mv1 order by id;
→ [{"id":1,"x1":11},{"id":2,"x1":21}]
select * from c_mv2 order by id;
→ [{"id":1,"x10":110},{"id":2,"x10":210}]

-- A single source insert converges the whole chain THIS commit
insert into c_t values (3, 30);
select * from c_mv2 order by id;
→ [{"id":1,"x10":110},{"id":2,"x10":210},{"id":3,"x10":310}]

-- ===================================
-- 14. Depth-3 chain (c_t → c_mv1 → c_mv2 → c_mv3): one source mutation converges
--     all three in the same commit.
-- ===================================

create materialized view c_mv3 as select id, x10 + 1 as x11 from c_mv2 with refresh = 'on-commit-incremental';
select * from c_mv3 order by id;
→ [{"id":1,"x11":111},{"id":2,"x11":211},{"id":3,"x11":311}]

insert into c_t values (4, 40);
select * from c_mv3 order by id;
→ [{"id":1,"x11":111},{"id":2,"x11":211},{"id":3,"x11":311},{"id":4,"x11":411}]

-- ===================================
-- 15. Aggregate dependent over a row-preserving leaf — an UPDATE that moves a
--     leaf row between groups drives BOTH the OLD and NEW group of the aggregate
--     dependent in the same commit (exercises the overlay's old/new projection).
-- ===================================

create table c_src (id integer primary key, k integer, v integer);
insert into c_src values (1, 1, 10), (2, 1, 20), (3, 2, 5);
create materialized view c_leaf as select id, k, v from c_src with refresh = 'on-commit-incremental';
create materialized view c_sum as select k, sum(v) as sv from c_leaf group by k with refresh = 'on-commit-incremental';
select * from c_sum order by k;
→ [{"k":1,"sv":30},{"k":2,"sv":5}]

-- Move id=2 from group k=1 → k=2: group 1 drops to 10, group 2 rises to 25
update c_src set k = 2 where id = 2;
select * from c_sum order by k;
→ [{"k":1,"sv":10},{"k":2,"sv":25}]

-- ===================================
-- 16. Cost-fallback / rebuild upstream propagates — a bulk insert demotes c_big1
--     to a full rebuild; c_big2 still converges (forced rebuild via the
--     globally-changed backing flag). Correct regardless of which path fires.
-- ===================================

create table c_big (id integer primary key, v integer);
insert into c_big values (1, 1), (2, 1);
create materialized view c_big1 as select id, v from c_big with refresh = 'on-commit-incremental';
create materialized view c_big2 as select id, v * 2 as v2 from c_big1 with refresh = 'on-commit-incremental';
insert into c_big values (3, 1), (4, 1), (5, 1), (6, 1), (7, 1), (8, 1), (9, 1), (10, 1);
select sum(v2) as total, count(*) as n from c_big2;
→ [{"total":20,"n":10}]

-- ===================================
-- 17. DELETE / predicate ripple — a row leaving (or entering) a leaf MV's
--     predicate, or a deleted source row, ripples through to the dependent the
--     same commit.
-- ===================================

create table c_f (id integer primary key, x integer);
insert into c_f values (1, 5), (2, 6), (3, -1);
create materialized view c_f1 as select id, x from c_f where x > 0 with refresh = 'on-commit-incremental';
create materialized view c_f2 as select id, x + 100 as y from c_f1 with refresh = 'on-commit-incremental';
select * from c_f2 order by id;
→ [{"id":1,"y":105},{"id":2,"y":106}]

-- id=1 leaves c_f1's predicate (x>0 → x=-2): its c_f2 row disappears this commit
update c_f set x = -2 where id = 1;
select * from c_f2 order by id;
→ [{"id":2,"y":106}]

-- id=3 enters c_f1's predicate (x=-1 → x=7): its c_f2 row appears this commit
update c_f set x = 7 where id = 3;
select * from c_f2 order by id;
→ [{"id":2,"y":106},{"id":3,"y":107}]

-- Deleting a source row removes the leaf row and ripples to the dependent
delete from c_f where id = 2;
select * from c_f2 order by id;
→ [{"id":3,"y":107}]

-- ===================================
-- 18. Composite-PK producer — a dependent over a multi-column group-by leaf MV.
--     The producer's backing PK is (g1, g2), so the overlay capture keys touched
--     rows via `buildPrimaryKeyFromValues` over a composite `backingPkDefinition`
--     and `pkToString`/`serializeTuple` must serialize composite keys without
--     collision. A source insert into one group ripples through to the dependent
--     the same commit.
-- ===================================

create table c_mc (id integer primary key, g1 integer, g2 integer, v integer);
insert into c_mc values (1, 1, 1, 10), (2, 1, 2, 20), (3, 2, 1, 5);
create materialized view c_grp as select g1, g2, sum(v) as sv from c_mc group by g1, g2 with refresh = 'on-commit-incremental';
create materialized view c_grp_d as select g1, g2, sv * 2 as sv2 from c_grp with refresh = 'on-commit-incremental';
select * from c_grp_d order by g1, g2;
→ [{"g1":1,"g2":1,"sv2":20},{"g1":1,"g2":2,"sv2":40},{"g1":2,"g2":1,"sv2":10}]

-- Insert into group (1,2): producer sv 20→120, dependent sv2 40→240, same commit.
-- Only that one composite-keyed group's overlay delta drives the dependent.
insert into c_mc values (4, 1, 2, 100);
select * from c_grp_d order by g1, g2;
→ [{"g1":1,"g2":1,"sv2":20},{"g1":1,"g2":2,"sv2":240},{"g1":2,"g2":1,"sv2":10}]

-- Cleanup (drop dependents before their producers)
drop materialized view c_grp_d;
drop materialized view c_grp;
drop materialized view c_mv3;
drop materialized view c_mv2;
drop materialized view c_mv1;
drop materialized view c_sum;
drop materialized view c_leaf;
drop materialized view c_big2;
drop materialized view c_big1;
drop materialized view c_f2;
drop materialized view c_f1;
drop table c_t;
drop table c_src;
drop table c_big;
drop table c_f;
drop table c_mc;

-- ===================================
-- 19. Multi-source INNER JOIN — parent/child flatten. The backing PK is the
--     child's (orders.id), so a CHILD-side change maintains incrementally
--     (orders.id ↦ physical PK, clean), while a PARENT-side change (customers)
--     does not cleanly cover the physical PK and falls back to a full rebuild.
--     Both outcomes converge the MV to the correct state. (Whichever path fires
--     is invisible to these correctness-only assertions.)
-- ===================================

create table customers (id integer primary key, name text);
create table orders (id integer primary key, cust_id integer, total integer);
insert into customers values (1, 'Alice'), (2, 'Bob'), (3, 'Carol');
insert into orders values (10, 1, 100), (11, 1, 200), (12, 2, 300), (20, 3, 500);
create materialized view mv_oc as
  select o.id as oid, c.name as cname, o.total as total
  from orders o join customers c on o.cust_id = c.id
  with refresh = 'on-commit-incremental';

-- MV equals the flattened join at create time
select * from mv_oc order by oid;
→ [{"oid":10,"cname":"Alice","total":100},{"oid":11,"cname":"Alice","total":200},{"oid":12,"cname":"Bob","total":300},{"oid":20,"cname":"Carol","total":500}]

-- CHILD UPDATE (orders.total) is reflected (clean child-side maintenance)
update orders set total = 999 where id = 10;
select * from mv_oc order by oid;
→ [{"oid":10,"cname":"Alice","total":999},{"oid":11,"cname":"Alice","total":200},{"oid":12,"cname":"Bob","total":300},{"oid":20,"cname":"Carol","total":500}]

-- CHILD INSERT (a new matching order) appears
insert into orders values (13, 2, 400);
select * from mv_oc order by oid;
→ [{"oid":10,"cname":"Alice","total":999},{"oid":11,"cname":"Alice","total":200},{"oid":12,"cname":"Bob","total":300},{"oid":13,"cname":"Bob","total":400},{"oid":20,"cname":"Carol","total":500}]

-- CHILD DELETE removes its MV row
delete from orders where id = 11;
select * from mv_oc order by oid;
→ [{"oid":10,"cname":"Alice","total":999},{"oid":12,"cname":"Bob","total":300},{"oid":13,"cname":"Bob","total":400},{"oid":20,"cname":"Carol","total":500}]

-- CHILD moved to a non-existent customer ⇒ inner join drops that MV row
-- (the residual recomputes zero rows, so the delete stands)
update orders set cust_id = 99 where id = 10;
select * from mv_oc order by oid;
→ [{"oid":12,"cname":"Bob","total":300},{"oid":13,"cname":"Bob","total":400},{"oid":20,"cname":"Carol","total":500}]

-- PARENT UPDATE (rename) ⇒ rebuild path; all that customer's MV rows show the new name
update customers set name = 'Robert' where id = 2;
select * from mv_oc order by oid;
→ [{"oid":12,"cname":"Robert","total":300},{"oid":13,"cname":"Robert","total":400},{"oid":20,"cname":"Carol","total":500}]

-- PARENT DELETE ⇒ rebuild path; the matching orders' MV rows vanish
delete from customers where id = 2;
select * from mv_oc order by oid;
→ [{"oid":20,"cname":"Carol","total":500}]

-- Manual refresh still resyncs a join MV (escape valve)
refresh materialized view mv_oc;
select * from mv_oc order by oid;
→ [{"oid":20,"cname":"Carol","total":500}]

-- BOTH sides change in one commit: the clean (child) side does point work, the
-- fan-out (parent) side forces a rebuild that also subsumes the child change —
-- correct regardless of dispatch order.
begin;
update orders set total = 555 where id = 20;
update customers set name = 'Caroline' where id = 3;
commit;
select * from mv_oc order by oid;
→ [{"oid":20,"cname":"Caroline","total":555}]

-- ===================================
-- 20. Both-clean 1:1 inner join (equal keys). Each side's PK equals the backing
--     PK, so an update on either side reflects correctly.
-- ===================================

create table ta (id integer primary key, x integer);
create table tb (id integer primary key, y integer);
insert into ta values (1, 10), (2, 20);
insert into tb values (1, 100), (2, 200);
create materialized view mv_ab as
  select ta.id as id, ta.x as x, tb.y as y
  from ta join tb on ta.id = tb.id
  with refresh = 'on-commit-incremental';
select * from mv_ab order by id;
→ [{"id":1,"x":10,"y":100},{"id":2,"x":20,"y":200}]

-- Update on the ta side reflects
update ta set x = 99 where id = 1;
select * from mv_ab order by id;
→ [{"id":1,"x":99,"y":100},{"id":2,"x":20,"y":200}]

-- Update on the tb side reflects
update tb set y = 999 where id = 2;
select * from mv_ab order by id;
→ [{"id":1,"x":99,"y":100},{"id":2,"x":20,"y":999}]

-- ===================================
-- 21. Eligibility rejections for multi-source bodies (all rejected at create).
-- ===================================

-- Outer join (left) is not maintainable yet
create materialized view mv_lj as select o.id as oid, c.name as cname from orders o left join customers c on o.cust_id = c.id with refresh = 'on-commit-incremental';
-- error: inner/cross

-- Aggregate over a join is deferred
create materialized view mv_aj as select c.id as cid, sum(o.total) as t from orders o join customers c on o.cust_id = c.id group by c.id with refresh = 'on-commit-incremental';
-- error: aggregate-over-join

-- `union all` survives the build-time gate but is rejected in compile()
create materialized view mv_ua as select id from orders union all select id from customers with refresh = 'on-commit-incremental';
-- error: set-operation

-- Cleanup (drop MVs before their source tables)
drop materialized view mv_oc;
drop materialized view mv_ab;
drop table orders;
drop table customers;
drop table ta;
drop table tb;
