-- adapted from SQLite test/expr2.test
-- IS TRUE / IS FALSE / IS NOT TRUE / IS NOT FALSE — boolean truth-value testing.
-- Existing 03-expressions covers IS NULL / IS NOT NULL.

create table is_bool (id integer primary key, b boolean null);
insert into is_bool values (1, true), (2, false), (3, null);

-- IS TRUE: NULL is not TRUE
select id, b is true as r from is_bool order by id;
→ [{"id":1,"r":true},{"id":2,"r":false},{"id":3,"r":false}]

-- IS NOT TRUE: NULL is "not true"
select id, b is not true as r from is_bool order by id;
→ [{"id":1,"r":false},{"id":2,"r":true},{"id":3,"r":true}]

-- IS FALSE: NULL is not FALSE
select id, b is false as r from is_bool order by id;
→ [{"id":1,"r":false},{"id":2,"r":true},{"id":3,"r":false}]

-- IS NOT FALSE: NULL is "not false"
select id, b is not false as r from is_bool order by id;
→ [{"id":1,"r":true},{"id":2,"r":false},{"id":3,"r":true}]

-- IS TRUE / IS FALSE in WHERE
select id from is_bool where b is true order by id;
→ [{"id":1}]

select id from is_bool where b is false order by id;
→ [{"id":2}]

select id from is_bool where b is not true order by id;
→ [{"id":2},{"id":3}]

select id from is_bool where b is not false order by id;
→ [{"id":1},{"id":3}]

-- IS TRUE / IS FALSE on expressions (predicates)
select (1 = 1) is true as r;
→ [{"r":true}]

select (1 = 2) is false as r;
→ [{"r":true}]

select (null = 1) is true as r;
→ [{"r":false}]

select (null = 1) is not true as r;
→ [{"r":true}]

select (null = 1) is false as r;
→ [{"r":false}]

select (null = 1) is not false as r;
→ [{"r":true}]

drop table is_bool;
