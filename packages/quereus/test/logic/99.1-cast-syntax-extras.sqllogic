-- adapted from SQLite test/cast.test, numcast.test, types2.test
-- Edge cases for CAST and conversion functions: BLOB roundtrips, scientific notation,
-- whitespace handling, NUMERIC affinity, INF/NaN, IN with mixed types.

-- =============================================================================
-- BLOB roundtrips via CAST
-- =============================================================================

-- CAST text to BLOB preserves bytes
select cast('hello' as blob) = x'68656c6c6f' as r;
→ [{"r":true}]

-- CAST BLOB back to TEXT decodes UTF-8
select cast(x'68656c6c6f' as text) as r;
→ [{"r":"hello"}]

-- BLOB roundtrip through CAST is identity for ASCII payloads
select cast(cast('abc' as blob) as text) as r;
→ [{"r":"abc"}]

-- BLOB equality after CAST
select cast(x'0102' as blob) = x'0102' as r;
→ [{"r":true}]

-- =============================================================================
-- Scientific notation in conversions
-- =============================================================================

-- CAST string with positive exponent
select cast('1.23e+2' as real) as r;
→ [{"r":123}]

-- CAST string with negative exponent
select cast('5e-1' as real) as r;
→ [{"r":0.5}]

-- real() function with exponent forms
select real('1e3') as r;
→ [{"r":1000}]

select real('1.5e-2') as r;
→ [{"r":0.015}]

-- CAST scientific to integer truncates
select cast('1.5e2' as integer) as r;
→ [{"r":150}]

-- =============================================================================
-- Whitespace handling in conversions
-- =============================================================================

-- Leading whitespace
select cast('  42' as integer) as r;
→ [{"r":42}]

select cast('  3.14' as real) as r;
→ [{"r":3.14}]

-- Trailing whitespace
select cast('42  ' as integer) as r;
→ [{"r":42}]

-- Surrounding whitespace
select integer('  -7  ') as r;
→ [{"r":-7}]

select real('  2.5  ') as r;
→ [{"r":2.5}]

-- =============================================================================
-- NUMERIC affinity-style CAST: integer-valued strings yield INTEGER
-- =============================================================================

-- '3.0' as NUMERIC: SQLite returns INTEGER 3
select cast('3.0' as numeric) as r;
→ [{"r":3}]

select typeof(cast('3.0' as numeric)) as r;
→ [{"r":"integer"}]

-- '3.5' as NUMERIC: stays REAL
select cast('3.5' as numeric) as r;
→ [{"r":3.5}]

select typeof(cast('3.5' as numeric)) as r;
→ [{"r":"real"}]

-- Plain integer string as NUMERIC
select cast('42' as numeric) as r;
→ [{"r":42}]

select typeof(cast('42' as numeric)) as r;
→ [{"r":"integer"}]

-- =============================================================================
-- IEEE 754 special values
-- =============================================================================

-- Positive infinity
select cast(1e400 as real) as r;
→ [{"r":null}]

-- Real arithmetic producing infinity
select 1.0 / 0.0 as r;
→ [{"r":null}]

-- NaN: 0.0 / 0.0
select 0.0 / 0.0 as r;
→ [{"r":null}]

-- typeof on infinity-producing expression
select typeof(1.0 / 0.0) as r;
→ [{"r":"null"}]

-- =============================================================================
-- IN with mixed-type literal lists (cross-category coercion)
-- =============================================================================

create table mix_in (id integer primary key, val integer);
insert into mix_in values (1, 10), (2, 20), (3, 30);

-- Integer column IN list with text literals: planner inserts cast on text literals
select val from mix_in where val in (10, '20', 30) order by val;
→ [{"val":10},{"val":20},{"val":30}]

-- IN with NULL in list: NULL doesn't match anything but doesn't filter non-NULL
select val from mix_in where val in (null, 10, 30) order by val;
→ [{"val":10},{"val":30}]

-- IN with text column and numeric literals
create table mix_in_text (id integer primary key, code text);
insert into mix_in_text values (1, '10'), (2, '20'), (3, '30');

select code from mix_in_text where code in ('10', 20, '30') order by code;
→ [{"code":"10"},{"code":"20"},{"code":"30"}]

drop table mix_in;
drop table mix_in_text;

-- =============================================================================
-- Real-to-text formatting edge cases
-- =============================================================================

-- Whole-number real
select text(1000.0) as r;
→ [{"r":"1000"}]

-- High-precision real
select text(3.141592653589793) as r;
→ [{"r":"3.141592653589793"}]

-- Small float in scientific range
select text(1e-10) as r;
→ [{"r":"1e-10"}]

-- =============================================================================
-- BOOLEAN <-> numeric edge cases
-- =============================================================================

-- BOOLEAN-typed literal coerced to integer
select cast(true as integer) + cast(false as integer) as r;
→ [{"r":1}]

-- Negative integer to boolean: nonzero is true
select cast(-1 as boolean) as r;
→ [{"r":true}]

-- Float to boolean
select cast(0.5 as boolean) as r;
→ [{"r":true}]

select cast(0.0 as boolean) as r;
→ [{"r":false}]
