-- Column-level ON CONFLICT directives in DDL (e.g.
-- `... PRIMARY KEY ON CONFLICT REPLACE`).  Quereus parses the syntax but does
-- NOT apply the directive as the default conflict resolution for that
-- constraint; statement-level OR clauses (or DEFAULT ABORT) win.  These cases
-- pin the actual Quereus behavior — without an explicit OR clause the duplicate
-- insert fails with the standard ABORT-style constraint error.

-- ===================================
-- 1. PRIMARY KEY ON CONFLICT REPLACE (column-level directive ignored)
-- ===================================

create table pk_replace (a integer primary key on conflict replace, b text);
insert into pk_replace values (1, 'first');

-- TODO bug: column-level ON CONFLICT REPLACE on PRIMARY KEY is parsed but not honored as default
-- duplicate insert should silently replace per the directive but Quereus aborts
insert into pk_replace values (1, 'second');
-- error: UNIQUE constraint failed

select a, b from pk_replace;
→ [{"a":1,"b":"first"}]

drop table pk_replace;

-- ===================================
-- 2. PRIMARY KEY ON CONFLICT IGNORE (column-level directive ignored)
-- ===================================

create table pk_ignore (a integer primary key on conflict ignore, b text);
insert into pk_ignore values (10, 'data');

-- TODO bug: column-level ON CONFLICT IGNORE on PRIMARY KEY is parsed but not honored as default
insert into pk_ignore values (10, 'conflict');
-- error: UNIQUE constraint failed

select count(*) as cnt from pk_ignore;
→ [{"cnt":1}]

drop table pk_ignore;

-- ===================================
-- 3. UNIQUE ON CONFLICT REPLACE (column-level directive ignored)
-- ===================================

create table uniq_replace (id integer primary key, email text unique on conflict replace);
insert into uniq_replace values (1, 'a@x');

-- TODO bug: column-level ON CONFLICT REPLACE on UNIQUE is parsed but not honored as default
insert into uniq_replace values (2, 'a@x');
-- error: UNIQUE constraint failed

select count(*) as cnt from uniq_replace;
→ [{"cnt":1}]

drop table uniq_replace;

-- ===================================
-- 4. NOT NULL ON CONFLICT IGNORE (column-level directive ignored)
-- ===================================

create table nn_ignore (id integer primary key, name text not null on conflict ignore);
insert into nn_ignore values (1, 'valid');

-- TODO bug: column-level ON CONFLICT IGNORE on NOT NULL is parsed but not honored as default
insert into nn_ignore (id) values (2);
-- error: NOT NULL constraint failed

select count(*) as cnt from nn_ignore;
→ [{"cnt":1}]

drop table nn_ignore;

-- ===================================
-- 5. CHECK ON CONFLICT IGNORE (column-level directive ignored)
-- ===================================

-- ON CONFLICT clause on a CHECK column constraint is not parsed by Quereus
create table ck_ignore (id integer primary key, n integer check (n > 0) on conflict ignore);
-- error: forget a comma before 'on'

-- ===================================
-- 6. Statement-level OR clause overrides column-level ON CONFLICT directive
-- ===================================

create table override_t (a integer primary key on conflict ignore, b text);
insert into override_t values (1, 'first');

-- statement-level OR ABORT should win over column-level directive (and is the actual Quereus default)
insert or abort into override_t values (1, 'second');
-- error: UNIQUE constraint failed

-- only original row remains
select a, b from override_t;
→ [{"a":1,"b":"first"}]

drop table override_t;
