-- Column-level ON CONFLICT directives in DDL (e.g.
-- `... PRIMARY KEY ON CONFLICT REPLACE`).  Quereus now honors these as the
-- per-constraint default conflict resolution.  Statement-level OR clauses
-- still take precedence over the column-level default.

-- ===================================
-- 1. PRIMARY KEY ON CONFLICT REPLACE — duplicate insert silently replaces
-- ===================================

create table pk_replace (a integer primary key on conflict replace, b text);
insert into pk_replace values (1, 'first');

insert into pk_replace values (1, 'second');

select a, b from pk_replace;
→ [{"a":1,"b":"second"}]

drop table pk_replace;

-- ===================================
-- 2. PRIMARY KEY ON CONFLICT IGNORE — duplicate insert silently dropped
-- ===================================

create table pk_ignore (a integer primary key on conflict ignore, b text);
insert into pk_ignore values (10, 'data');

insert into pk_ignore values (10, 'conflict');

select a, b from pk_ignore;
→ [{"a":10,"b":"data"}]

drop table pk_ignore;

-- ===================================
-- 3. UNIQUE ON CONFLICT REPLACE — second insert replaces existing row
-- ===================================

create table uniq_replace (id integer primary key, email text unique on conflict replace);
insert into uniq_replace values (1, 'a@x');

insert into uniq_replace values (2, 'a@x');

-- The new row (id=2) wins; the old one is replaced.
select id, email from uniq_replace order by id;
→ [{"id":2,"email":"a@x"}]

drop table uniq_replace;

-- ===================================
-- 4. NOT NULL ON CONFLICT IGNORE — violating row silently skipped
-- ===================================

create table nn_ignore (id integer primary key, name text not null on conflict ignore);
insert into nn_ignore values (1, 'valid');

insert into nn_ignore (id) values (2);

select id, name from nn_ignore order by id;
→ [{"id":1,"name":"valid"}]

drop table nn_ignore;

-- ===================================
-- 5. CHECK ON CONFLICT IGNORE — parser accepts; violations silently skipped
-- ===================================

create table ck_ignore (id integer primary key, n integer check (n > 0) on conflict ignore);
insert into ck_ignore values (1, 10);

-- CHECK violation under column-level IGNORE: row dropped.
insert into ck_ignore values (2, -5);

select id, n from ck_ignore order by id;
→ [{"id":1,"n":10}]

drop table ck_ignore;

-- ===================================
-- 6. Statement-level OR clause overrides column-level ON CONFLICT directive
-- ===================================

create table override_t (a integer primary key on conflict ignore, b text);
insert into override_t values (1, 'first');

-- statement-level OR ABORT must beat the column-level IGNORE directive.
insert or abort into override_t values (1, 'second');
-- error: UNIQUE constraint failed

-- only original row remains
select a, b from override_t;
→ [{"a":1,"b":"first"}]

drop table override_t;
