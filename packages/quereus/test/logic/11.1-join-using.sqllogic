-- adapted from SQLite test/join.test, joinB.test, joinH.test
-- USING clause: column merging, multi-column USING, mismatched types, collation.

create table u_a (id integer primary key, k integer, va text);
create table u_b (id integer primary key, k integer, vb text);

insert into u_a values (1, 100, 'a1'), (2, 200, 'a2'), (3, 300, 'a3');
insert into u_b values (10, 100, 'b1'), (20, 200, 'b2'), (40, 999, 'b4');

-- Single-column USING: shared column appears once, with right-side row also visible
select * from u_a join u_b using (k) order by u_a.id;
→ [{"k":100,"id":1,"va":"a1","id:1":10,"vb":"b1"},{"k":200,"id":2,"va":"a2","id:1":20,"vb":"b2"}]

-- USING column referenced unqualified
select k, va, vb from u_a join u_b using (k) order by k;
→ [{"k":100,"va":"a1","vb":"b1"},{"k":200,"va":"a2","vb":"b2"}]

-- LEFT JOIN with USING preserves left rows; right-side merged column shows left value
select u_a.id, k, vb from u_a left join u_b using (k) order by u_a.id;
→ [{"id":1,"k":100,"vb":"b1"},{"id":2,"k":200,"vb":"b2"},{"id":3,"k":300,"vb":null}]

drop table u_a;
drop table u_b;
-- run

-- Multi-column USING (a, b)
create table mu_l (a integer, b integer, vl text);
create table mu_r (a integer, b integer, vr text);

insert into mu_l values (1, 10, 'l1'), (2, 20, 'l2'), (3, 10, 'l3');
insert into mu_r values (1, 10, 'r1'), (2, 30, 'r2'), (3, 10, 'r3');

-- Both keys must match for inner USING join
select a, b, vl, vr from mu_l join mu_r using (a, b) order by a, b;
→ [{"a":1,"b":10,"vl":"l1","vr":"r1"},{"a":3,"b":10,"vl":"l3","vr":"r3"}]

-- LEFT JOIN with multi-column USING
select a, b, vl, vr from mu_l left join mu_r using (a, b) order by a, b;
→ [{"a":1,"b":10,"vl":"l1","vr":"r1"},{"a":2,"b":20,"vl":"l2","vr":null},{"a":3,"b":10,"vl":"l3","vr":"r3"}]

drop table mu_l;
drop table mu_r;
-- run

-- USING column referenced via either table-qualified form remains valid in projection
create table uq_a (id integer primary key, k integer, x text);
create table uq_b (id integer primary key, k integer, y text);
insert into uq_a values (1, 5, 'A'), (2, 6, 'B');
insert into uq_b values (10, 5, 'P'), (20, 7, 'Q');

select uq_a.k, uq_a.x, uq_b.y from uq_a join uq_b using (k) order by uq_a.id;
→ [{"k":5,"x":"A","y":"P"}]

drop table uq_a;
drop table uq_b;
-- run

-- USING with TEXT keys (collation-binary by default)
create table cu_a (id integer primary key, name text);
create table cu_b (id integer primary key, name text);

insert into cu_a values (1, 'alice'), (2, 'BOB'), (3, 'carol');
insert into cu_b values (10, 'alice'), (20, 'bob'), (30, 'carol');

-- Default binary collation: 'BOB' != 'bob'
select cu_a.id, cu_a.name, cu_b.id from cu_a join cu_b using (name) order by cu_a.id;
→ [{"id":1,"name":"alice","id:1":10},{"id":3,"name":"carol","id:1":30}]

drop table cu_a;
drop table cu_b;
-- run

-- USING (name) with NOCASE collation declared on the column should allow case-insensitive match
create table cu_nocase_a (id integer primary key, name text collate nocase);
create table cu_nocase_b (id integer primary key, name text collate nocase);

insert into cu_nocase_a values (1, 'alice'), (2, 'BOB'), (3, 'carol');
insert into cu_nocase_b values (10, 'ALICE'), (20, 'bob'), (30, 'CAROL');

select cu_nocase_a.id, cu_nocase_b.id from cu_nocase_a join cu_nocase_b using (name) order by cu_nocase_a.id;
→ [{"id":1,"id:1":10},{"id":2,"id:1":20},{"id":3,"id:1":30}]

drop table cu_nocase_a;
drop table cu_nocase_b;
