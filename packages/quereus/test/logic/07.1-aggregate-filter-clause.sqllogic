-- adapted from SQLite test/aggfunc.test, test/window4.test, test/window6.test
-- FILTER (WHERE …) clause restricts which rows feed an aggregate or window aggregate.

create table af (id integer primary key, grp text, val integer null, flag integer);
insert into af values
  (1, 'a', 10, 1),
  (2, 'a', 20, 0),
  (3, 'b', 30, 1),
  (4, 'b', 40, 0),
  (5, 'c', null, 1);

-- count(*) FILTER over the whole table
select count(*) filter (where val > 15) as c from af;
→ [{"c":3}]

-- sum() FILTER
select sum(val) filter (where flag = 1) as s from af;
→ [{"s":40}]

-- avg() FILTER excludes filtered-out rows from the average
select avg(val) filter (where flag = 0) as a from af;
→ [{"a":30}]

-- FILTER combined with GROUP BY: each group's filter is independent
select grp,
       count(*) filter (where flag = 1) as c_active,
       sum(val) filter (where flag = 1) as s_active,
       sum(val) filter (where flag = 0) as s_inactive
from af group by grp order by grp;
→ [{"grp":"a","c_active":1,"s_active":10,"s_inactive":20},{"grp":"b","c_active":1,"s_active":30,"s_inactive":40},{"grp":"c","c_active":1,"s_active":null,"s_inactive":null}]

-- FILTER alongside non-FILTER aggregate in same query
select count(*) as total, count(*) filter (where flag = 1) as actives from af;
→ [{"total":5,"actives":3}]

-- FILTER condition that matches no rows: aggregate sees empty input
select count(*) filter (where val > 9999) as c, sum(val) filter (where val > 9999) as s from af;
→ [{"c":0,"s":null}]

-- FILTER with HAVING: HAVING evaluates after filtered aggregate
select grp, count(*) filter (where flag = 1) as c_active
from af group by grp having count(*) filter (where flag = 1) > 0 order by grp;
→ [{"grp":"a","c_active":1},{"grp":"b","c_active":1},{"grp":"c","c_active":1}]

-- DISTINCT inside FILTER aggregate
select count(distinct grp) filter (where val is not null) as c from af;
→ [{"c":2}]

drop table af;

-- =============================================================================
-- FILTER on window aggregate functions
-- =============================================================================

create table wf (id integer primary key, val integer, flag integer);
insert into wf values (1, 10, 1), (2, 20, 0), (3, 30, 1), (4, 40, 0), (5, 50, 1);

-- Running count of "active" rows (flag = 1)
select id, val, count(*) filter (where flag = 1) over (order by id rows unbounded preceding) as c_active
from wf order by id;
→ [{"id":1,"val":10,"c_active":1},{"id":2,"val":20,"c_active":1},{"id":3,"val":30,"c_active":2},{"id":4,"val":40,"c_active":2},{"id":5,"val":50,"c_active":3}]

-- Running sum filtered by flag, partitioned
create table wfp (id integer primary key, grp text, val integer, flag integer);
insert into wfp values (1, 'a', 10, 1), (2, 'a', 20, 0), (3, 'a', 30, 1), (4, 'b', 40, 1), (5, 'b', 50, 0);

select id, grp, val,
       sum(val) filter (where flag = 1) over (partition by grp order by id rows unbounded preceding) as running_active
from wfp order by id;
→ [{"id":1,"grp":"a","val":10,"running_active":10},{"id":2,"grp":"a","val":20,"running_active":10},{"id":3,"grp":"a","val":30,"running_active":40},{"id":4,"grp":"b","val":40,"running_active":40},{"id":5,"grp":"b","val":50,"running_active":40}]

drop table wf;
drop table wfp;
