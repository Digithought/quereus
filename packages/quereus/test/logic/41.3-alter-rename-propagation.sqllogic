-- adapted from SQLite test/alter.test and test/altertab.test
-- RENAME TABLE / RENAME COLUMN must propagate into dependent objects:
-- views, CHECK constraints, FOREIGN KEY references, indexes, CTEs in views.

-- ===================================
-- 1. RENAME TABLE referenced by a CHECK constraint
-- ===================================

create table t_chk (id integer primary key, v integer not null);
alter table t_chk add constraint c1 check ((select count(*) from t_chk) >= 0);

alter table t_chk rename to t_chk2;

insert into t_chk2 values (1, 10);

select count(*) as cnt from t_chk2;
→ [{"cnt":1}]

drop table t_chk2;

-- ===================================
-- 2. RENAME TABLE referenced by a partial-index WHERE clause
-- ===================================

create table t_pidx (id integer primary key, v integer not null);
create index ix_t_pidx on t_pidx(v) where v > 0;

alter table t_pidx rename to t_pidx2;

insert into t_pidx2 values (1, 5), (2, -1);

select v from t_pidx2 where v > 0 order by v;
→ [{"v":5}]

drop table t_pidx2;

-- ===================================
-- 3. RENAME TABLE referenced by a FOREIGN KEY in another table
-- ===================================

pragma foreign_keys = true;

create table parent_t (id integer primary key, name text);
create table child_t (id integer primary key, pid integer not null references parent_t(id) on delete restrict on update restrict);

insert into parent_t values (1, 'p');
insert into child_t values (10, 1);

-- Force a checkpoint here so the deferred FK check from the legitimate insert
-- evaluates against the still-current parent_t before we rename it.
select count(*) as cnt from child_t;
→ [{"cnt":1}]

alter table parent_t rename to parent_t2;

select count(*) as cnt from parent_t2;
→ [{"cnt":1}]

-- FK still enforced under new parent name (bad pid → fail at commit)
insert into child_t values (11, 99);
-- error: CHECK constraint failed: _fk_child_t

-- valid child reference still works under the new parent name
insert into child_t values (12, 1);

select count(*) as cnt from child_t;
→ [{"cnt":2}]

drop table child_t;
drop table parent_t2;

-- ===================================
-- 4. RENAME TABLE referenced inside a view's SELECT
-- ===================================

create table tv_src (id integer primary key, name text);
insert into tv_src values (1, 'a');

create view vv as select id, name from tv_src;

alter table tv_src rename to tv_src2;

select * from vv;
→ [{"id":1,"name":"a"}]

drop view vv;
drop table tv_src2;

-- ===================================
-- 5. RENAME COLUMN propagates into a view's projection / WHERE
-- ===================================

create table t_vc (id integer primary key, old_n text);
insert into t_vc values (1, 'a'), (2, 'b');

create view v_vc as select id, old_n from t_vc where old_n is not null;

alter table t_vc rename column old_n to new_n;

select * from v_vc order by id;
→ [{"id":1,"new_n":"a"},{"id":2,"new_n":"b"}]

drop view v_vc;
drop table t_vc;

-- ===================================
-- 6. RENAME COLUMN referenced inside a CTE in a view
-- ===================================

-- TODO bug: rename propagation through views (including CTEs in views) is unimplemented
-- create table t_cte (id integer primary key, k integer not null);
-- insert into t_cte values (1, 10), (2, 20);
--
-- create view v_cte as with c as (select k from t_cte) select k from c;
--
-- alter table t_cte rename column k to kk;
--
-- select * from v_cte order by kk;
-- → [{"kk":10},{"kk":20}]
--
-- drop view v_cte;
-- drop table t_cte;

-- ===================================
-- 7. RENAME COLUMN referenced inside an index expression
-- ===================================

-- Quereus doesn't support indices on expressions yet; rename propagation tested elsewhere
create table t_idxc (id integer primary key, v integer not null);
create index ix_idxc on t_idxc(v + 1);
-- error: not supported

drop table if exists t_idxc;

-- ===================================
-- 8. Aliased renamed table inside a view body
-- ===================================

create table tv_src3 (id integer primary key, name text);
insert into tv_src3 values (1, 'a'), (2, 'b');

create view va as select x.id, x.name from tv_src3 as x;

alter table tv_src3 rename to tv_src3_renamed;

select * from va order by id;
→ [{"id":1,"name":"a"},{"id":2,"name":"b"}]

drop view va;
drop table tv_src3_renamed;

-- ===================================
-- 9. Renaming a table referenced by a CHECK on a different table
-- ===================================

create table a_smoke (id integer primary key);
create table b_smoke (id integer primary key, check ((select count(*) from a_smoke) >= 0));

alter table a_smoke rename to a_smoke2;

insert into b_smoke values (1);

select count(*) as cnt from b_smoke;
→ [{"cnt":1}]

drop table b_smoke;
drop table a_smoke2;

-- ===================================
-- 10. Renaming a column referenced by another table's CHECK
-- ===================================

create table p_col (id integer primary key, k integer not null);
insert into p_col values (1, 1);

create table c_col (
  id integer primary key,
  check ((select count(*) from p_col where p_col.k > 0) >= 0)
);

alter table p_col rename column k to kk;

insert into c_col values (1);

select count(*) as cnt from c_col;
→ [{"cnt":1}]

drop table c_col;
drop table p_col;
